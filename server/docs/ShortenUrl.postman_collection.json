{
  "info": {
    "name": "ShortenUrl API (v1 - mock)",
    "description": "Mocked URL shortener API. Set collection variables baseUrl and token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "mock.jwt.token" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (201)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password1\",\n  \"name\": \"Test User\"\n}" }
          }
        },
        {
          "name": "Register - validation failure (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"nope\",\n  \"password\": \"123\"\n}" }
          }
        },
        {
          "name": "Register - email conflict (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"existing@example.com\",\n  \"password\": \"password1\"\n}" }
          }
        },
        {
          "name": "Login (200)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password1\"\n}" }
          }
        },
        {
          "name": "Login - invalid credentials (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"wrongpassword\"\n}" }
          }
        }
      ]
    },
    {
      "name": "URLs",
      "item": [
        {
          "name": "Create URL (201)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/v1/urls",
            "body": { "mode": "raw", "raw": "{\n  \"originalUrl\": \"https://example.com/some/long/path\",\n  \"customAlias\": \"mylink\"\n}" }
          }
        },
        {
          "name": "Create URL - no token (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/urls",
            "body": { "mode": "raw", "raw": "{\n  \"originalUrl\": \"https://example.com\"\n}" }
          }
        },
        {
          "name": "Create URL - invalid URL (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/v1/urls",
            "body": { "mode": "raw", "raw": "{\n  \"originalUrl\": \"not-a-url\"\n}" }
          }
        },
        {
          "name": "Create URL - alias conflict (409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/v1/urls",
            "body": { "mode": "raw", "raw": "{\n  \"originalUrl\": \"https://example.com\",\n  \"customAlias\": \"taken\"\n}" }
          }
        },
        {
          "name": "List URLs (200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/urls"
          }
        },
        {
          "name": "Get URL by id (200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/urls/url_1"
          }
        },
        {
          "name": "Get URL - not found (404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/urls/missing"
          }
        },
        {
          "name": "Update URL (200)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/v1/urls/url_1",
            "body": { "mode": "raw", "raw": "{\n  \"originalUrl\": \"https://example.com/updated\"\n}" }
          }
        },
        {
          "name": "Delete URL (204)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/urls/url_1"
          }
        },
        {
          "name": "Analytics (200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/urls/url_1/analytics"
          }
        }
      ]
    },
    {
      "name": "Redirect",
      "item": [
        {
          "name": "Redirect (302)",
          "request": { "method": "GET", "url": "{{baseUrl}}/abc123" }
        },
        {
          "name": "Redirect - expired (410)",
          "request": { "method": "GET", "url": "{{baseUrl}}/expired" }
        },
        {
          "name": "Redirect - not found (404)",
          "request": { "method": "GET", "url": "{{baseUrl}}/missing" }
        }
      ]
    }
  ]
}
